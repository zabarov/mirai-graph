{
  "schema_version": "0.1.0",
  "seed_id": "seed.organization_governance_pilot",
  "target_graph_id": "graph.organization_governance_pilot",
  "purpose": "Create a public-safe GrowGraph package for organization governance.",
  "target_profile": "profile.organization_governance",
  "target_mode": "pilot",
  "graph_dna": {
    "purpose": "Keep mission, strategy, decision rights, risks, controls, metrics and improvement proposals connected.",
    "evolution_vector": "Grow from a small governance pilot into a repeatable operating model for organization-scale control.",
    "non_negotiable_principles": [
      "The pilot must remain synthetic and public-safe.",
      "Decision rights must be explicit before policy or portfolio changes.",
      "Feedback and evidence may inform proposals but cannot automatically update canonical state."
    ]
  },
  "source_boundaries": {
    "allowed_sources": [
      "synthetic organization governance brief",
      "public GrowGraph organization-governance profile",
      "public GrowGraph governance standard docs"
    ],
    "excluded_sources": [
      "private company data",
      "employee records",
      "customer records",
      "internal policy text",
      "private workflow traces",
      "secrets or credentials"
    ],
    "canonical_write_allowed": false
  },
  "growth_rules": {
    "allowed_object_families": [
      "organization",
      "mission",
      "strategy",
      "portfolio",
      "department",
      "program",
      "objective",
      "policy",
      "decision_right",
      "governance_gate",
      "role",
      "capability",
      "risk",
      "control",
      "metric",
      "feedback",
      "kaizen_item",
      "evidence"
    ],
    "allowed_relation_families": [
      "aligns_with",
      "owns",
      "belongs_to",
      "governs",
      "requires_approval",
      "controls",
      "mitigates",
      "measures",
      "supports",
      "depends_on",
      "blocks",
      "escalates_to",
      "produces_feedback",
      "improves",
      "evidences",
      "related_to"
    ],
    "max_initial_objects": 20,
    "depth_mode": "standard"
  },
  "review_gates": [
    "strategy_alignment_before_portfolio_change",
    "decision_right_before_policy_change",
    "risk_control_before_cross_department_action",
    "evidence_before_governance_decision",
    "kaizen_before_process_promotion",
    "no_generated_context_as_authorization",
    "no_feedback_as_automatic_update"
  ],
  "generated_views": [
    "strategy_alignment_view",
    "decision_rights_view",
    "risk_control_view",
    "metric_dashboard_view",
    "kaizen_queue_view"
  ],
  "stop_conditions": [
    "private_company_data_requested",
    "decision_right_missing_for_policy_change",
    "feedback_treated_as_automatic_update",
    "secret_or_credential_detected"
  ]
}
