{
  "id": "profile.skill_runtime",
  "name": "Skill Runtime",
  "version": "0.1.0",
  "description": "Profile for modeling a governed skill, capability module or service as a Hybrid Source Of Truth runtime context.",
  "allowed_object_kinds": [
    "skill",
    "capability",
    "activity",
    "rule",
    "owner_domain",
    "source_boundary",
    "raw_source",
    "runtime_context",
    "projection_view",
    "quality_gate",
    "adoption_report",
    "effectiveness_report",
    "semantic_review",
    "runtime_policy",
    "fallback",
    "handoff",
    "learning_proposal",
    "federation_contract",
    "governance_gate",
    "evidence"
  ],
  "allowed_relation_types": [
    "owns_domain",
    "has_capability",
    "supports_activity",
    "uses_rule",
    "requires_gate",
    "requires_fallback",
    "reads_source",
    "generates_context",
    "projects_view",
    "evidences",
    "preserves_semantics",
    "measures_effectiveness",
    "routes_to",
    "hands_off_to",
    "exports_contract",
    "federates_with",
    "proposes_learning",
    "governs",
    "related_to"
  ],
  "default_readiness": "draft",
  "governance_gates": [
    "human_review_before_canonical_write",
    "semantic_preservation_before_runtime",
    "effectiveness_before_federation",
    "runtime_enablement_before_primary_context",
    "fallback_required_for_sensitive_tasks",
    "public_safety_before_release"
  ]
}
