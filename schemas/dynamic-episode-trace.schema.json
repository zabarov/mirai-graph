{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/dynamic-episode-trace.schema.json",
  "title": "Mirai Graph Dynamic Episode Trace",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "profile",
    "public_safety",
    "event",
    "source_refs",
    "activated",
    "selected_path",
    "blocked_paths",
    "gates",
    "actions",
    "results",
    "findings",
    "feedback_classification",
    "kaizen_candidates",
    "replay_regression",
    "evidence_refs",
    "limitations",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "profile": { "const": "dynamic_episode_layer" },
    "public_safety": { "const": "synthetic_public" },
    "event": {
      "type": "object",
      "required": ["id", "type", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "source_refs": {
      "type": "object",
      "required": ["graph_refs", "workflow_refs", "launch_record_ref"],
      "properties": {
        "spec_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "graph_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "workflow_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "launch_record_ref": { "type": "string", "minLength": 1 }
      }
    },
    "activated": {
      "type": "object",
      "required": ["objects", "relations", "policies", "gates", "technology_steps"],
      "properties": {
        "objects": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "relations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "policies": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "gates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "technology_steps": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "selected_path": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason", "blocked_by"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "blocked_by": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 }
        }
      }
    },
    "actions": { "type": "array" },
    "results": { "type": "array" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "classification", "severity", "summary", "evidence_refs", "next_route", "blocking"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "classification": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "next_route": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "feedback_classification": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "kaizen_candidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "replay_regression": {
      "type": "object",
      "required": ["replay_ready", "baseline_ref", "regression_check_ref"],
      "properties": {
        "replay_ready": { "type": "boolean" },
        "baseline_ref": { "type": ["string", "null"] },
        "regression_check_ref": { "type": ["string", "null"] }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "canonical_write_allowed": { "const": false }
  }
}
