{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/context-pack.schema.json",
  "title": "GrowGraph Context Pack",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "task_id",
    "source_graph",
    "generated_at",
    "included_objects",
    "included_relations",
    "evidence",
    "limitations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_graph": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "included_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "included_relations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "omissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
