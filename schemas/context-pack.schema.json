{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/context-pack.schema.json",
  "title": "Mirai Graph Context Pack",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "task_id",
    "source_graph",
    "generated_at",
    "included_objects",
    "included_relations",
    "evidence",
    "selection",
    "limitations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_graph": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "included_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "included_relations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selection": {
      "type": "object",
      "required": [
        "method",
        "task_tokens",
        "object_explanations",
        "relation_explanations"
      ],
      "additionalProperties": true,
      "properties": {
        "method": {
          "type": "string"
        },
        "task_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "object_explanations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "relevance_score", "reasons"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "relevance_score": {
                "type": "number"
              },
              "reasons": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "relation_explanations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "reason", "source", "target"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "target": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "omissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
