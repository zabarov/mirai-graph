{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/implementation-control-loop.schema.json",
  "title": "GrowGraph Implementation Control Loop",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "profile",
    "source_graph",
    "baseline",
    "projection_view",
    "semantic_review",
    "evidence_pack",
    "sync_proposal",
    "approval_gate",
    "controlled_update",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "const": "implementation_control"
    },
    "source_graph": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": "string",
      "minLength": 1
    },
    "projection_view": {
      "type": "string",
      "minLength": 1
    },
    "semantic_review": {
      "type": "string",
      "minLength": 1
    },
    "evidence_pack": {
      "type": "string",
      "minLength": 1
    },
    "sync_proposal": {
      "type": "string",
      "minLength": 1
    },
    "launch_gate": {
      "type": "string",
      "minLength": 1
    },
    "approval_gate": {
      "type": "string",
      "minLength": 1
    },
    "controlled_update": {
      "type": "string",
      "minLength": 1
    },
    "drift_check": {
      "type": "string",
      "minLength": 1
    },
    "kaizen_item": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
