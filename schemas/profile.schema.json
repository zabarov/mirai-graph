{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/profile.schema.json",
  "title": "Mirai Graph Profile",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "allowed_object_kinds",
    "allowed_relation_types",
    "default_readiness",
    "governance_gates"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "allowed_object_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_relation_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_readiness": {
      "type": "string"
    },
    "governance_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
