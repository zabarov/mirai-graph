{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/implementation-control-cycle.schema.json",
  "title": "GrowGraph Implementation Control Cycles",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "profile",
    "public_safety",
    "cycles",
    "cycle_transitions",
    "kaizen_finding_taxonomy",
    "kaizen_blocking_findings",
    "kaizen_default_rule",
    "boundaries",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "const": "implementation_control"
    },
    "public_safety": {
      "const": "synthetic_public"
    },
    "cycles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "purpose",
          "stages",
          "inputs",
          "outputs",
          "gates",
          "validators",
          "recovery_behavior",
          "repeat_condition",
          "promotion_path",
          "evidence_refs",
          "limitations"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "stages": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "executable_states": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "projection_stages": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "human_stages": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "state_mapping": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          },
          "state_machine_id": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "validators": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "recovery_behavior": {
            "type": "string",
            "minLength": 1
          },
          "repeat_condition": {
            "type": "string",
            "minLength": 1
          },
          "promotion_path": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "cycle_transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "from",
          "to",
          "trigger",
          "required_outputs",
          "required_gates",
          "handoff_artifact",
          "owner",
          "failure_behavior",
          "recovery_behavior"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "required_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "handoff_artifact": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "failure_behavior": {
            "type": "string",
            "minLength": 1
          },
          "recovery_behavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "kaizen_finding_taxonomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "kaizen_blocking_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "kaizen_default_rule": {
      "type": "string",
      "minLength": 1
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
