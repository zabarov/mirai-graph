{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/launch-record.schema.json",
  "title": "Mirai Graph Launch Record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "profile",
    "public_safety",
    "workflow_id",
    "process_model_id",
    "cycle_id",
    "current_state",
    "target_state",
    "allowed_files",
    "forbidden_files",
    "allowed_actions",
    "required_gates",
    "required_evidence",
    "stop_conditions",
    "owner_role",
    "approved_by_user",
    "evidence_refs",
    "limitations"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "profile": { "const": "implementation_control" },
    "public_safety": { "const": "synthetic_public" },
    "workflow_id": { "type": "string", "minLength": 1 },
    "process_model_id": { "type": "string", "minLength": 1 },
    "cycle_id": { "type": "string", "minLength": 1 },
    "current_state": { "type": "string", "minLength": 1 },
    "target_state": { "type": "string", "minLength": 1 },
    "allowed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "owner_role": { "type": "string", "minLength": 1 },
    "approved_by_user": { "type": "boolean" },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
