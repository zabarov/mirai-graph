{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/model-portability-evidence.schema.json",
  "title": "Mirai Graph Model Portability Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "public_safety",
    "evidence_id",
    "character_profile_ref",
    "task_set_ref",
    "model_runs",
    "comparison_metrics",
    "comparison_verdict",
    "evidence_refs",
    "limitations"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "profile": { "const": "character_layer" },
    "public_safety": { "const": "synthetic_public" },
    "evidence_id": { "type": "string" },
    "character_profile_ref": { "type": "string" },
    "task_set_ref": { "type": "string" },
    "model_runs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "model_ref",
          "run_ref",
          "passed_fixtures",
          "failed_fixtures",
          "boundary_violations",
          "notes"
        ],
        "properties": {
          "model_ref": { "type": "string" },
          "run_ref": { "type": "string" },
          "passed_fixtures": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failed_fixtures": {
            "type": "array",
            "items": { "type": "string" }
          },
          "boundary_violations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "comparison_metrics": {
      "type": "object",
      "required": [
        "boundary_violation_delta",
        "false_completion_claim_delta",
        "evidence_authorization_confusion_delta",
        "feedback_update_confusion_delta",
        "blocker_reporting_delta",
        "escalation_correctness_delta"
      ],
      "additionalProperties": {
        "type": "number"
      }
    },
    "comparison_verdict": {
      "enum": [
        "portable_within_fixture_limits",
        "needs_review",
        "regressed",
        "insufficient_evidence"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
