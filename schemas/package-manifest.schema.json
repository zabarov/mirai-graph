{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirai-graph.dev/schemas/package-manifest.schema.json",
  "title": "Mirai Graph Package Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "version", "profile", "conformance_level", "graph"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "conformance_level": {
      "type": "string",
      "enum": ["level_0", "level_1", "level_2", "level_3", "level_4"]
    },
    "graph": {
      "type": "object",
      "required": ["objects", "relations"],
      "properties": {
        "objects": {
          "type": "string",
          "minLength": 1
        },
        "relations": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "public_safety": {
      "type": "string"
    }
  }
}
