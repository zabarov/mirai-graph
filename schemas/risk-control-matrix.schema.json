{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/risk-control-matrix.schema.json",
  "title": "Mirai Graph Risk Control Matrix",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "profile", "public_safety", "risks", "evidence_refs", "limitations"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "profile": { "const": "implementation_control" },
    "public_safety": { "const": "synthetic_public" },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "severity", "description", "detection_signal", "prevention", "gate_or_validator", "evidence_requirement", "recovery_action", "escalation_rule", "owner_role"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "description": { "type": "string", "minLength": 1 },
          "detection_signal": { "type": "string", "minLength": 1 },
          "prevention": { "type": "string", "minLength": 1 },
          "gate_or_validator": { "type": "string", "minLength": 1 },
          "evidence_requirement": { "type": "string", "minLength": 1 },
          "recovery_action": { "type": "string", "minLength": 1 },
          "escalation_rule": { "type": "string", "minLength": 1 },
          "owner_role": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
