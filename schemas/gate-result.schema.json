{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/gate-result.schema.json",
  "title": "Mirai Graph Governance Gate Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "gate_id", "target_id", "verdict", "summary", "evidence", "reviewed_at"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass_with_notes", "blocked", "rejected", "needs_more_evidence"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string"
    }
  }
}
