{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/technology-quality-feedback.schema.json",
  "title": "GrowGraph Technology Quality Feedback",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "profile",
    "public_safety",
    "technology_ref",
    "process_id",
    "launch_record_ref",
    "work_evidence_refs",
    "required_steps",
    "completed_steps",
    "missing_steps",
    "review_dimensions",
    "findings",
    "feedback_classification",
    "blocking_findings",
    "verdict",
    "next_transition",
    "kaizen_refs",
    "evidence_refs",
    "limitations"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "profile": { "const": "implementation_control" },
    "public_safety": { "const": "synthetic_public" },
    "technology_ref": { "type": "string", "minLength": 1 },
    "process_id": { "type": "string", "minLength": 1 },
    "launch_record_ref": { "type": "string", "minLength": 1 },
    "work_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "completed_steps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_steps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "review_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "dimension",
          "classification",
          "severity",
          "summary",
          "evidence_refs",
          "next_route",
          "blocking"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "dimension": { "type": "string", "minLength": 1 },
          "classification": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "next_route": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "feedback_classification": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "blocking_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verdict": { "type": "string", "minLength": 1 },
    "next_transition": { "type": "string", "minLength": 1 },
    "kaizen_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
