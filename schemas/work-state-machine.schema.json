{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/work-state-machine.schema.json",
  "title": "GrowGraph Work State Machine",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "profile", "public_safety", "states", "transitions", "false_transition_guards", "evidence_refs", "limitations"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "profile": { "const": "implementation_control" },
    "public_safety": { "const": "synthetic_public" },
    "states": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
    "terminal_states": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "requires_evidence"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "requires_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "requires_launch_record": { "type": "boolean" },
          "terminal_requires_kaizen": { "type": "boolean" }
        }
      }
    },
    "false_transition_guards": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
