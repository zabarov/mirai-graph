{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growgraph.dev/schemas/object.schema.json",
  "title": "Mirai Graph Object",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "kind", "title", "summary", "readiness", "evidence", "profile"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "readiness": {
      "type": "string",
      "enum": ["draft", "review_ready", "accepted", "blocked", "deprecated"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
