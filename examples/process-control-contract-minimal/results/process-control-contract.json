{
  "schema_version": "0.1.0",
  "id": "process_control_contract.synthetic_executable_process",
  "profile": "implementation_control",
  "public_safety": "synthetic_public",
  "process_id": "process.synthetic_executable_standard",
  "cycle_id": "bounded_work_batch",
  "state_machine_id": "work_state_machine.synthetic_executable_process",
  "launch_record_policy": {
    "required_for_states": ["ready_to_execute", "started"],
    "required_for_transitions": ["planned->ready_to_execute", "ready_to_execute->started"],
    "approval_required": true
  },
  "evidence_requirements": [
    "launch_record",
    "scope_check",
    "test_result",
    "technology_quality_feedback",
    "semantic_acceptance",
    "release_evidence"
  ],
  "recovery_behavior": "Resume from durable workflow state, last valid launch record and evidence pack.",
  "risk_controls": [
    "terminal_without_kaizen",
    "sync_proposal_as_update",
    "tests_without_acceptance",
    "technology_drift_without_feedback"
  ],
  "validators": [
    "launch-record",
    "process-transition",
    "technology-quality-feedback",
    "work-state-machine"
  ],
  "technology_quality_feedback_policy": {
    "required_for_transitions": [
      "tests_recorded->review_ready",
      "review_ready->approved",
      "approved->release_ready"
    ],
    "accepted_verdicts": [
      "accepted",
      "accepted_with_deferred_items"
    ],
    "blocking_findings_stop_transition": true
  },
  "kaizen_policy": {
    "terminal_state_requires_review_or_skip": true,
    "accepted_skip_field": "no_reusable_lessons_reason"
  },
  "evidence_refs": [
    "evidence.synthetic_process_contract_brief"
  ],
  "limitations": [
    "Synthetic contract validates executable process shape, not real-world safety.",
    "The contract does not execute actions or approve canonical updates."
  ]
}
